# Application
APP_NAME=HyperScale
APP_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
API_V1_PREFIX=/api/v1
BASE_URL=http://localhost:8000

# Database (Use Supabase free tier for production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/hyperscale
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/hyperscale

# Redis (Use Upstash free tier for production)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=["http://localhost:3000","https://hyperscale.vercel.app"]

# Short URL
SHORT_URL_LENGTH=7
SHORT_URL_DOMAIN=http://localhost:8000
